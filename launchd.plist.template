<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>at.dasgeht.callwatch</string>
	<key>ProgramArguments</key>
	<array>
		<string>__HOME__/Applications/calltap.app/Contents/MacOS/calltap</string>
		<string>watch</string>
		<string>--config</string>
		<string>__HOME__/.config/callnotes/config.json</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>ThrottleInterval</key>
	<integer>10</integer>
	<key>ProcessType</key>
	<string>Interactive</string>
	<key>LimitLoadToSessionType</key>
	<string>Aqua</string>
	<key>StandardOutPath</key>
	<string>__HOME__/CallNotes/log/callwatch.log</string>
	<key>StandardErrorPath</key>
	<string>__HOME__/CallNotes/log/callwatch.log</string>
</dict>
</plist>
